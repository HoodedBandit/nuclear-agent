{
  "tasks": [
    {
      "id": "py-bugfix",
      "fixture": "../../fixtures/py_bugfix",
      "suite": "bug-fix",
      "prompt": "Inspect the repository, fix the broken calculator addition behavior, rerun the tests, and summarize the concrete fix.",
      "deterministic_script": "../../fixtures/py_bugfix/script.json",
      "setup_commands": [],
      "expected_failure_before_run": [
        {
          "label": "bug is present before the run",
          "argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-p", "test_*.py"],
          "expected_exit_code": 1,
          "timeout_seconds": 30
        }
      ],
      "success_commands": [
        {
          "label": "calculator tests pass",
          "argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-p", "test_*.py"],
          "timeout_seconds": 30
        }
      ],
      "allowed_change_globs": ["calculator.py"],
      "forbidden_change_globs": ["README.md", "tests/**"],
      "expected_changed_paths": ["calculator.py"],
      "max_duration_seconds": 120,
      "max_tool_calls": 8,
      "required_tools": ["read_file", "run_shell", "apply_patch"],
      "requires_network": false,
      "requires_shell": true,
      "requires_edit": true,
      "final_response_assertions": {
        "contains_all": ["Fixed", "tests"],
        "not_contains": ["I could not"]
      }
    },
