#!/bin/sh

set -eu

step() {
  printf '==> %s\n' "$1"
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

script_dir() {
  CDPATH= cd -- "$(dirname -- "$0")" && pwd
}

resolve_source_root() {
  source_probe_root="$1"
  if [ -f "$source_probe_root/source/Cargo.toml" ]; then
    printf '%s\n' "$source_probe_root/source"
    return
  fi
  if [ -f "$source_probe_root/Cargo.toml" ]; then
    printf '%s\n' "$source_probe_root"
    return
  fi
  echo "Could not locate the project source directory." >&2
  exit 1
}

cargo_target_root() {
  root="$1"
  if [ -n "${CARGO_TARGET_DIR:-}" ]; then
    case "$CARGO_TARGET_DIR" in
      /*) printf '%s\n' "$CARGO_TARGET_DIR" ;;
      *) printf '%s\n' "$root/$CARGO_TARGET_DIR" ;;
    esac
    return
  fi

  printf '%s\n' "$root/target"
}

resolve_bundled_binary() {
  binary_root="$1"
  cargo_target_root_value="$(cargo_target_root "$binary_root")"
  machine_arch="$(uname -m)"
  case "$machine_arch" in
    x86_64|amd64)
      if [ -x "$binary_root/bin/linux-x64/nuclear" ]; then
        printf '%s\n' "$binary_root/bin/linux-x64/nuclear"
        return
      fi
      ;;
    aarch64|arm64)
      if [ -x "$binary_root/bin/linux-arm64/nuclear" ]; then
        printf '%s\n' "$binary_root/bin/linux-arm64/nuclear"
        return
      fi
      ;;
  esac

  if [ -x "$cargo_target_root_value/release/nuclear" ]; then
    printf '%s\n' "$cargo_target_root_value/release/nuclear"
    return
  fi

  printf '\n'
}

install_rustup() {
  step "Rust toolchain not found; installing rustup"
  if command_exists curl; then
    curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal
  elif command_exists wget; then
    wget -q -O - https://sh.rustup.rs | sh -s -- -y --profile minimal
  else
    echo "curl or wget is required to install Rust automatically." >&2
    exit 1
  fi
  export PATH="$HOME/.cargo/bin:$PATH"
}

ensure_cargo() {
  if command_exists cargo; then
    initialize_rustup_env "$(command -v cargo)"
    return
  fi
  install_rustup
  if ! command_exists cargo; then
    echo "cargo is still unavailable after rustup installation." >&2
    exit 1
  fi
  initialize_rustup_env "$(command -v cargo)"
}

initialize_rustup_env() {
  cargo_path="$1"
  if [ -z "$cargo_path" ]; then
    return
  fi

  cargo_bin_dir="$(CDPATH= cd -- "$(dirname -- "$cargo_path")" && pwd)"
  cargo_home="$(CDPATH= cd -- "$cargo_bin_dir/.." && pwd)"
  if [ -z "${CARGO_HOME:-}" ] && [ -x "$cargo_home/bin/cargo" ]; then
    export CARGO_HOME="$cargo_home"
  fi

  if [ -n "${RUSTUP_HOME:-}" ]; then
    return
  fi

  cargo_home_parent="$(CDPATH= cd -- "$cargo_home/.." && pwd)"
  rustup_home="$cargo_home_parent/.rustup"
  if [ -f "$rustup_home/settings.toml" ]; then
    export RUSTUP_HOME="$rustup_home"
  fi
}

choose_install_dir() {
  if [ -n "${NUCLEAR_INSTALL_DIR:-}" ]; then
    printf '%s\n' "$NUCLEAR_INSTALL_DIR"
    return
  fi

  if [ -n "${AUTISM_INSTALL_DIR:-}" ]; then
    step "AUTISM_INSTALL_DIR is deprecated; using it once for migration compatibility"
    printf '%s\n' "$AUTISM_INSTALL_DIR"
    return
  fi

  if [ -n "${CARGO_HOME:-}" ] && [ -d "$CARGO_HOME/bin" ]; then
    case ":$PATH:" in
      *":$CARGO_HOME/bin:"*)
        printf '%s\n' "$CARGO_HOME/bin"
        return
        ;;
    esac
  fi

  case ":$PATH:" in
    *":$HOME/.cargo/bin:"*)
      printf '%s\n' "$HOME/.cargo/bin"
      return
      ;;
    *":$HOME/.local/bin:"*)
      printf '%s\n' "$HOME/.local/bin"
      return
      ;;
  esac

  printf '%s\n' "$HOME/.local/bin"
}

add_to_path() {
  path_install_dir="$1"
  shell_profile="$HOME/.profile"

  case "${SHELL:-}" in
    */bash)
      shell_profile="$HOME/.bashrc"
      ;;
    */zsh)
      shell_profile="$HOME/.zshrc"
      ;;
  esac

  if [ "${NUCLEAR_SKIP_PATH_PERSIST:-${AUTISM_SKIP_PATH_PERSIST:-0}}" = "1" ]; then
    step "Skipped persistent PATH changes for this install run"
    return
  fi

  profile_line="export PATH=\"$path_install_dir:\$PATH\""
  if [ -f "$shell_profile" ] && grep -F "$profile_line" "$shell_profile" >/dev/null 2>&1; then
    step "PATH is already configured for future shells in $shell_profile"
    return
  fi

  case ":$PATH:" in
    *":$path_install_dir:"*)
      step "Persisting $path_install_dir to $shell_profile for future shells"
      ;;
  esac

  {
    printf '\n# Added by Nuclear Agent installer\n'
    printf '%s\n' "$profile_line"
  } >>"$shell_profile"
  step "Updated PATH for future shells in $shell_profile"
}

install_binary_atomic() {
  atomic_source_binary="$1"
  atomic_target_binary="$2"
  atomic_tmp_binary="$atomic_target_binary.new"
  cp "$atomic_source_binary" "$atomic_tmp_binary"
  chmod 0755 "$atomic_tmp_binary"
  mv -f "$atomic_tmp_binary" "$atomic_target_binary"
}

rollback_binary_path() {
  install_dir="$1"
  printf '%s\n' "$install_dir/.rollback/nuclear"
}

backup_installed_binary() {
  source_binary="$1"
  install_dir="$2"
  if [ ! -f "$source_binary" ]; then
    printf '\n'
    return
  fi
  rollback_binary="$(rollback_binary_path "$install_dir")"
  mkdir -p "$(dirname "$rollback_binary")"
  cp "$source_binary" "$rollback_binary"
  chmod 0755 "$rollback_binary"
  printf '%s\n' "$rollback_binary"
}

write_install_state() {
  install_dir="$1"
  version="$2"
  install_source="$3"
  rollback_binary="$4"
  previous_binary_source="$5"
  cat >"$install_dir/install-state.json" <<EOF
{
  "schema_version": 1,
  "display_name": "Nuclear Agent",
  "command_name": "nuclear",
  "install_dir": "$install_dir",
  "installed_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "version": "$version",
  "install_source": "$install_source",
  "rollback_binary": "$rollback_binary",
  "previous_binary_source": "$previous_binary_source"
}
EOF
}

install_rollback_companion() {
  source_root="$1"
  install_dir="$2"
  rollback_script="$source_root/scripts/rollback-install.sh"
  if [ ! -f "$rollback_script" ]; then
    echo "Rollback script was not found at $rollback_script" >&2
    exit 1
  fi
  cp "$rollback_script" "$install_dir/nuclear-rollback"
  chmod 0755 "$install_dir/nuclear-rollback"
}

stop_installed_processes() {
  managed_binary_path="$1"

  if [ ! -x "$managed_binary_path" ]; then
    return
  fi

  step "Stopping any running Nuclear Agent compatibility processes from the install directory"
  "$managed_binary_path" daemon stop >/dev/null 2>&1 || true
  sleep 1

  if command_exists pgrep; then
    pgrep -f "$managed_binary_path" 2>/dev/null | while IFS= read -r pid; do
      [ -n "$pid" ] || continue
      kill "$pid" 2>/dev/null || true
    done
    sleep 1
  fi
}

build_binary_from_source() {
  build_source_root="$1"
  install_target_binary="$2"
  cargo_target_root_value="$(cargo_target_root "$build_source_root")"
  ensure_cargo
  step "Building Nuclear Agent from source"
  cargo build --release --bin nuclear --manifest-path "$build_source_root/Cargo.toml"
  built_binary="$cargo_target_root_value/release/nuclear"
  if [ ! -x "$built_binary" ]; then
    echo "Cargo reported success but $built_binary was not found." >&2
    exit 1
  fi
  install_binary_atomic "$built_binary" "$install_target_binary"
}

case "$(uname -s)" in
  Linux)
    ;;
  *)
    echo "install supports Linux only. Use install.ps1 on Windows." >&2
    exit 1
    ;;
esac

root="$(script_dir)"
source_root="$(resolve_source_root "$root")"
install_dir="$(choose_install_dir)"
binary_path="$install_dir/nuclear"
bundled_binary="$(resolve_bundled_binary "$root")"

step "Installing Nuclear Agent CLI"
step "Install directory: $install_dir"
mkdir -p "$install_dir"
previous_binary_source=""
for candidate in "$binary_path" "$install_dir/autism"; do
  if [ -f "$candidate" ]; then
    previous_binary_source="$candidate"
    break
  fi
done
rollback_binary=""
if [ -n "$previous_binary_source" ]; then
  rollback_binary="$(backup_installed_binary "$previous_binary_source" "$install_dir")"
fi
stop_installed_processes "$binary_path"
stop_installed_processes "$install_dir/autism"

if [ -n "$bundled_binary" ]; then
  step "Using bundled Linux binary"
  install_binary_atomic "$bundled_binary" "$binary_path"
else
  build_binary_from_source "$source_root" "$binary_path"
fi

rm -f "$install_dir/autism"

version="$("$binary_path" --version)"
write_install_state "$install_dir" "$version" "$( [ -n "$bundled_binary" ] && printf 'bundled' || printf 'source_build' )" "$rollback_binary" "$previous_binary_source"
install_rollback_companion "$source_root" "$install_dir"
add_to_path "$install_dir"

step "Installed version: $version"
if command -v nuclear >/dev/null 2>&1; then
  step "Run: nuclear"
else
  step "Open a new terminal and run: nuclear"
fi
if [ -n "$rollback_binary" ]; then
  step "Rollback script: $install_dir/nuclear-rollback"
fi
